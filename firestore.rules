rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Admin is identified by email in the Firebase Auth token — no doc read needed.
    function isAdmin() {
      return isAuthed() && request.auth.token.email == 'admin@email.com';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read any user doc (needed for display names, avatars).
    // create: owner only (prevents impersonation).
    // update: owner (profile edits) OR admin (fund injection, isAdmin bootstrap).
    // delete: never.
    match /users/{uid} {
      allow read:   if isAuthed();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;

      // ── Deposits subcollection ─────────────────────────────────────────────
      // Admin can create deposits for any user (fund injection).
      // Read is open to all authed users for the Admin transaction log.
      match /deposits/{depositId} {
        allow read:   if isAuthed();
        allow create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // ── Deposits collectionGroup ───────────────────────────────────────────
    // Required for collectionGroup('deposits') queries in Admin transaction log.
    // The recursive wildcard {path=**} matches deposits under any parent path.
    match /{path=**}/deposits/{depositId} {
      allow read: if isAuthed();
    }

    // ── Wagers ────────────────────────────────────────────────────────────────
    // Creator or opponent can read. Either party can update (accept/decline/settle).
    // Any authed user can create (createWager validates creator == request.auth.uid).
    match /wagers/{wagerId} {
      allow read:   if isAuthed() &&
                       (resource.data.creatorId == request.auth.uid ||
                        resource.data.opp       == request.auth.uid);
      allow create: if isAuthed() &&
                       request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthed() &&
                       (resource.data.creatorId == request.auth.uid ||
                        resource.data.opp       == request.auth.uid);
      allow delete: if false;

      // ── Messages subcollection ────────────────────────────────────────────
      // Only the two wager participants can read or post messages.
      // Messages are immutable once written (no update/delete).
      match /messages/{msgId} {
        allow read, create: if isAuthed() && (
          get(/databases/$(database)/documents/wagers/$(wagerId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/wagers/$(wagerId)).data.opp       == request.auth.uid
        );
        allow update, delete: if false;
      }
    }

    // ── H2H records ───────────────────────────────────────────────────────────
    // Doc ID is "{uidA}_{uidB}" (sorted). Either of the two users can read/write.
    match /h2h/{h2hId} {
      allow read:  if isAuthed();
      allow write: if isAuthed();
    }

    // ── Posts ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read posts (social feed).
    // Only the author can create/update their own posts.
    match /posts/{postId} {
      allow read:   if isAuthed();
      allow create: if isAuthed() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAuthed() &&
                       resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

  }
}
